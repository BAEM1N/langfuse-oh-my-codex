# Langfuse credentials for langfuse-oh-my-codex
# Copy this file to ~/.omx/.env and fill in your values.
# Environment variables take priority over .env values.

TRACE_TO_LANGFUSE=true
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_USER_ID=omx-user

# Optional
# LANGFUSE_DEBUG=true
# LANGFUSE_MAX_REASONING_BLOCKS=200
